{
  "name": "surge-merge",
  "version": "0.1.0",
  "description": "Merge Surge profiles with AI routing rules",
  "bin": {
    "surge-merge": "./src/main.ts"
  },
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "schema": "bun run src/main.ts @schema",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "check": "bun run fmt:check && bun run typecheck && bun test",
    "build": "bun build src/main.ts --outfile=dist/surge-merge --target=bun --minify && chmod +x dist/surge-merge"
  },
  "dependencies": {
    "@valibot/to-json-schema": "^1.7.0",
    "argc": "github:ethan-huo/argc#v7.5.0",
    "valibot": "^1.4.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260603.1",
    "oxfmt": "^0.53.0",
    "typescript": "npm:@typescript/typescript6@^6.0.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
